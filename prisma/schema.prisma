generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Job {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  slug             String   @unique
  title            String
  organization     String
  category         String
  startDate        DateTime
  endDate          DateTime
  eligibility      String
  selectionProcess String
  howToApply       String
  description      String
  applyLink        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model User {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  name     String?
  email    String   @unique
  password String
  role     String   @default("ADMIN")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
